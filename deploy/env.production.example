# Copie para a raiz do projeto como .env
# PowerShell: Copy-Item deploy\env.production.example ..\.env

# Modo desenvolvimento — 1 = visitantes veem «site em construção»; admin autenticado passa
# Produção / site público: SITE_DEV_MODE=0 ou comente a linha
SITE_DEV_MODE=0

PORT=8080
SITE_URL=https://inspetorbudganja.com.br

# Painel admin — altere em produção
ADMIN_USER=admin
RESEARCH_PASS=

# Conta Google (cadastro de utilizadores — /entrar.html)
# Crie em https://console.cloud.google.com/apis/credentials (OAuth 2.0 Client ID → Web application)
# Origens autorizadas: https://inspetorbudganja.com.br e http://localhost:8080 (dev)
GOOGLE_CLIENT_ID=

# Inspetor BudGanja IA (Gemini) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Opcional — aviso por e-mail quando alguém se inscreve em avisos de sorteio
# Gmail: ative verificação em 2 passos e crie uma "Senha de app" em https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=
# NOTIFY_EMAIL=inspetorbudganja@gmail.com

# Opcional
YOUTUBE_CHANNEL_ID=
NETLIFY_BUILD_HOOK=
