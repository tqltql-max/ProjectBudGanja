# Inspetor BudGanja — variáveis de ambiente (copie para .env)
# Nunca commite o ficheiro .env

ADMIN_USER=admin
RESEARCH_PASS=altere-esta-senha

PORT=8080
SITE_URL=https://inspetorbudganja.com.br

# Login Google (utilizadores — Diário de Pesquisas /perfil.html)
GOOGLE_CLIENT_ID=
# Necessário para OAuth redirect (/api/auth/google/start)
GOOGLE_CLIENT_SECRET=
# E-mails Google com acesso admin (separados por vírgula)
# ADMIN_EMAILS=admin@example.com

# Armazenamento: sql (SQLite local), fs ou blobs (Netlify)
# STORE_BACKEND=sql

# Modo construção: 1 = visitantes veem página «em construção»
# SITE_DEV_MODE=0

# YouTube RSS
YOUTUBE_CHANNEL_ID=UCv6U48NA-zeDCRxmegfe7NQ

# Backup externo da BD (opcional)
# BUDGANJA_BACKUP_DIR=C:\Users\voce\BudGanjaBackups

# Netlify / Turso (produção)
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=
# NETLIFY_BUILD_HOOK=

# E-mail transacional (SMTP — Gmail com palavra-passe de app recomendada)
# GMAIL_USER=inspetorbudganja@gmail.com
# GMAIL_APP_PASSWORD=
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# NOTIFY_EMAIL=inspetorbudganja@gmail.com
